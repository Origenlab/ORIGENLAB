---
{/* pagina-categoria.astro — CATEGORÍA (L2): intro + grid de fichas + interlinking + FAQ. Origen: PROYECTORED (CategoryLayout) + patrón D2 */}

// ============================================================================
// CATEGORÍA — Nivel L2. Landing de un dominio (una categoría de producto o
// servicio). Lista las fichas hijas (L4) y enlaza lateralmente a otras
// categorías (interlinking deliberado, B6). Copia a, p.ej.,
// src/pages/{categoria}/index.astro y rellena {{...}}.
//
// pageType="category". buildSchema emite CollectionPage/ItemList + FAQPage (si
// hay faqs) + BreadcrumbList (una vez). Las FAQ visibles y las del schema usan
// las MISMAS preguntas (regla Google: contenido = schema).
//
// Patrón L2 (PROYECTORED): breadcrumb → hero → contenido (grid) → FAQ → CTA.
// El orden lo da PageLayout (header/breadcrumbs/footer); aquí va el contenido.
// ============================================================================

import PageLayout from "@layouts/PageLayout.astro";
import Hero from "@components/Hero.astro";
import SectionHeading from "@components/SectionHeading.astro";
import ProductCard from "@components/ProductCard.astro";
import FAQAccordion from "@components/FAQAccordion.astro";
import RelatedLinks from "@components/RelatedLinks.astro";
import CTABanner from "@components/CTABanner.astro";
import { TAXONOMY, waUrl } from "@config/site";
// Si las fichas viven en una Content Collection, descomenta y filtra por categoría:
// import { getCollection } from "astro:content";
// const items = (await getCollection("productos")).filter((p) => p.data.category === CATEGORY_SLUG);

const CATEGORY_SLUG = "{{CATEGORIA_SLUG}}";
const CATEGORY_LABEL = "{{CATEGORIA_LABEL}}";
const waLink = waUrl();

// Otras categorías para interlinking lateral (excluye la actual).
const otherCategories = TAXONOMY.categories.filter((c) => c.slug !== CATEGORY_SLUG);

// FAQ de la categoría — mismas preguntas alimentan el FAQPage del schema.
const faqs = [
  { q: "{{PREGUNTA_1}}", a: "{{RESPUESTA_1}}" },
  { q: "{{PREGUNTA_2}}", a: "{{RESPUESTA_2}}" },
];

const breadcrumbs = [
  { label: CATEGORY_LABEL },
];

// schemaData (claves EXACTAS del contrato lib/seo.ts):
//   list { name, description, path, items[] } → CollectionPage + ItemList.
//   faqs → FAQPage (mismas preguntas que el bloque visible).
const schemaData = {
  list: {
    name: CATEGORY_LABEL,
    description: "{{META_DESCRIPTION_CATEGORIA}}",
    path: `/${CATEGORY_SLUG}`,
    items: [
      // Si usas colección: items.map((i) => ({ name: i.data.title, path: `/${CATEGORY_SLUG}/${i.id}` }))
      { name: "{{FICHA_1_TITULO}}", path: "{{FICHA_1_HREF}}" },
      { name: "{{FICHA_2_TITULO}}", path: "{{FICHA_2_HREF}}" },
      { name: "{{FICHA_3_TITULO}}", path: "{{FICHA_3_HREF}}" },
    ],
  },
  faqs: faqs.map((f) => ({ question: f.q, answer: f.a })),
};
---

<PageLayout
  title={`${CATEGORY_LABEL} en {{CIUDAD}}`}
  description="{{META_DESCRIPTION_CATEGORIA_140_160}}"
  pageType="category"
  schemaData={schemaData}
  breadcrumbs={breadcrumbs}
>
  {/* ── HERO de categoría ── */}
  <Hero
    badge={CATEGORY_LABEL}
    title="{{HERO_TITULO_CATEGORIA}}"
    subtitle="{{HERO_SUBTITULO_CATEGORIA}}"
    ctas={[
      { text: "Cotizar por WhatsApp", href: waLink, variant: "primary", whatsapp: true },
      { text: "Hablar con un asesor", href: "/contacto", variant: "outline" },
    ]}
  />

  {/* ── INTRO de categoría (texto SEO + contexto) ── */}
  <section class="cat-intro">
    <div class="container">
      <SectionHeading eyebrow="{{KICKER_INTRO}}" title="{{TITULO_INTRO}}" />
      <p>{{PARRAFO_INTRO_1}}</p>
      <p>{{PARRAFO_INTRO_2}}</p>
    </div>
  </section>

  {/* ── GRID de fichas hijas (L4) ── */}
  <section class="cat-grid">
    <div class="container">
      <SectionHeading title={`Todo en ${CATEGORY_LABEL}`} />
      <div class="cat-grid__items">
        {/* Si usas colección: items.map((item) => (...)). Aquí, marcadores estáticos: */}
        <ProductCard title="{{FICHA_1_TITULO}}" href="{{FICHA_1_HREF}}" description="{{FICHA_1_DESC}}" />
        <ProductCard title="{{FICHA_2_TITULO}}" href="{{FICHA_2_HREF}}" description="{{FICHA_2_DESC}}" />
        <ProductCard title="{{FICHA_3_TITULO}}" href="{{FICHA_3_HREF}}" description="{{FICHA_3_DESC}}" />
      </div>
    </div>
  </section>

  {/* ── INTERLINKING: otras categorías (B6) ── */}
  <section class="cat-related">
    <div class="container">
      <SectionHeading eyebrow="Explora más" title="Otras categorías" />
      <RelatedLinks links={otherCategories.map((c) => ({ label: c.label, href: c.href }))} />
    </div>
  </section>

  {/* ── FAQ (mismas preguntas que el FAQPage del schema) ── */}
  <section class="cat-faq">
    <div class="container">
      <SectionHeading eyebrow="Preguntas frecuentes" title={`Sobre ${CATEGORY_LABEL}`} />
      <FAQAccordion items={faqs.map((f) => ({ question: f.q, answer: f.a }))} />
    </div>
  </section>

  {/* ── CTA de cierre ── */}
  <CTABanner
    heading={`¿Necesitas ${CATEGORY_LABEL}?`}
    desc="Mándanos lo que buscas y te cotizamos con precio y disponibilidad."
    btns={[{ label: "Cotizar por WhatsApp", href: waLink, icon: "wa", primary: true, external: true }]}
  />
</PageLayout>

<style>
  .cat-intro, .cat-grid, .cat-related, .cat-faq { padding: var(--space-10) 0; }
  .cat-intro p { max-width: var(--container-prose); color: var(--color-text-muted); margin-bottom: var(--space-3); }
  .cat-grid__items { display: grid; grid-template-columns: 1fr; gap: var(--space-5); margin-top: var(--space-8); }
  .cat-related { background: var(--color-surface); }
  @media (min-width: 768px) {
    .cat-grid__items { grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); }
  }
</style>
