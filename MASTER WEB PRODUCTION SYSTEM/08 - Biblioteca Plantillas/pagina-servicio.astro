---
{/* pagina-servicio.astro — ruta dinámica de FICHA DE SERVICIO (L4) desde la colección `servicios`. Origen: CLINICADEBELLEZA (servicios/[...slug]) + getStaticPaths */}

// ============================================================================
// FICHA DE SERVICIO (L4) — ruta dinámica schema-driven.
// Copia a src/pages/servicios/[...slug].astro
//
// Genera UNA página por entrada de la Content Collection `servicios`
// (ver _scaffold/content.config.ts). El ServiceLayout decide qué secciones
// pintar según qué bloques traen datos — origen CLINICADEBELLEZA, el layout
// más flexible del Master System. Toda entidad repetible = Content Collection (D1).
//
// CONTRATO DE DATOS (campos garantizados por la colección `servicios`):
//   title, description, category, image, pricing?, includes?, isHub,
//   relatedServices?, relatedProducts?, hero?, faqs?, featured, order, draft, seo*.
//
// ⭐ BLOQUES EDITORIALES OPCIONALES (los 10 de CLINICADEBELLEZA: protocolSteps,
// timeline, preCare, postCare, comparison, modalities, clinicalCases,
// treatmentZones, myths, commitments, safetyProtocol). NO vienen en el schema
// base `servicios`. Para fichas ricas tipo clínica/estética, AÑÁDELOS al schema
// `servicios` en content.config.ts (copia los bloques de la nota del Índice de
// Plantillas) y descomenta el mapeo de abajo. ServiceLayout ya los acepta y solo
// pinta la sección si el array trae datos (no rompe si faltan).
// ============================================================================

import { getCollection, getEntries, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import ServiceLayout from "@layouts/ServiceLayout.astro";

export async function getStaticPaths() {
  const servicios = await getCollection("servicios", ({ data }) => !data.draft);
  return servicios.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<"servicios"> };
const { entry } = Astro.props;
const d = entry.data;

// Interlinking: resuelve servicios/productos relacionados (reference() tipado).
const relatedRefs = [...(d.relatedServices ?? []), ...(d.relatedProducts ?? [])];
const relatedEntries = relatedRefs.length ? await getEntries(relatedRefs as any) : [];
const related = relatedEntries.map((r: any) => ({
  label: r.data.title,
  href: `/${r.collection === "productos" ? "productos" : "servicios"}/${r.id}`,
  description: r.data.description,
}));

const { Content } = await render(entry);
---

<ServiceLayout
  slug={entry.id}
  title={d.title}
  description={d.description}
  category={d.category}
  seoTitle={d.seoTitle}
  seoDescription={d.seoDescription}
  image={d.image}
  heroLede={d.hero?.subtitle}
  price={d.pricing?.note}
  benefits={d.includes}
  faqs={d.faqs?.map((f) => ({ q: f.question, a: f.answer }))}
  related={related}
>
  {/*
    ⭐ Bloques editoriales (descomenta tras añadirlos a la colección `servicios`):
    heroTagline={d.heroTagline}
    duration={d.duration}
    sessions={d.sessions}
    indications={d.indications}
    contraindications={d.contraindications}
    protocolSteps={d.protocolSteps}
    timeline={d.timeline}
    preCare={d.preCare}
    postCare={d.postCare}
    comparison={d.comparison}
    modalities={d.modalities}
    clinicalCases={d.clinicalCases}
    treatmentZones={d.treatmentZones}
    myths={d.myths}
    commitments={d.commitments}
    safetyProtocol={d.safetyProtocol}
  */}
  <Content />
</ServiceLayout>
