---
{/* pagina-directorio-[...slug].astro — DIRECTORIO/ZONA (arquetipo D): ruta dinámica multinivel desde colección con getStaticPaths. Origen: EVENTECH (directorio/[...slug]) */}

// ============================================================================
// DIRECTORIO (arquetipo D) — ruta dinámica multinivel.
// Copia a src/pages/directorio/[...slug].astro
//
// Un solo archivo [...slug].astro genera TRES niveles de página desde la
// colección `directorio` (origen EVENTECH, 211 venues de terceros en 3 niveles):
//   /directorio/{region}/                      → listado de la región (CollectionPage + ItemList)
//   /directorio/{region}/{zona}/               → listado de la zona     (CollectionPage + ItemList)
//   /directorio/{region}/{zona}/{item-slug}/   → ficha individual del item
//
// Toda la "inteligencia" de presentación vive en el TEMPLATE, no en el .md
// (RENTADEILUMINACION/EVENTECH). El .md solo aporta datos. Las páginas de
// listado son imán SEO local que enlaza a las fichas y al catálogo.
//
// ⚠️ REQUIERE una colección `directorio` (distinta de `zonas`/`casos` del
// content.config.ts base — `zonas` es arquetipo C: una página por zona propia;
// ESTO es arquetipo D: directorio de entidades de terceros — salones, empresas,
// estaciones). Añade esta colección a content.config.ts:
//
//   const directorio = defineCollection({
//     loader: glob({ pattern: '**/*.md', base: './src/content/directorio' }),
//     schema: z.object({
//       title: z.string(),              // nombre del item (salón/empresa)
//       description: z.string(),
//       region: z.enum(['{{REGION_1}}', '{{REGION_2}}']), // nivel 1
//       zone: z.string(),               // nombre humano de la zona (nivel 2)
//       zoneSlug: z.string(),           // slug de la zona (para la URL)
//       image: z.string().regex(/^\/images\//).optional(),
//       phone: z.string().optional(),
//       active: z.boolean().default(true),
//     }).strict(),
//   });
//   // export const collections = { ..., directorio };
// ============================================================================

import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import SectionHeading from "@components/SectionHeading.astro";
import RelatedLinks from "@components/RelatedLinks.astro";
import CTABanner from "@components/CTABanner.astro";
import { waUrl } from "@config/site";

type Item = CollectionEntry<"directorio">;

export async function getStaticPaths() {
  const all: Item[] = await getCollection("directorio", ({ data }) => data.active !== false);
  const paths: { params: { slug: string }; props: Record<string, unknown> }[] = [];

  // Regiones únicas (enum del schema, ej. 'cdmx' | 'estado-mexico').
  const regions = [...new Set(all.map((i) => i.data.region))];

  for (const region of regions) {
    const regionItems = all.filter((i) => i.data.region === region);
    const zones = [...new Set(regionItems.map((i) => i.data.zoneSlug))];

    // Nivel 1: /directorio/{region}/
    paths.push({
      params: { slug: region },
      props: { type: "region", region, zones, items: regionItems },
    });

    for (const zone of zones) {
      const zoneItems = regionItems.filter((i) => i.data.zoneSlug === zone);
      const zoneName = zoneItems[0]?.data.zone ?? zone;

      // Nivel 2: /directorio/{region}/{zona}/
      paths.push({
        params: { slug: `${region}/${zone}` },
        props: { type: "zone", region, zone, zoneName, items: zoneItems },
      });

      // Nivel 3: /directorio/{region}/{zona}/{item-slug}/
      for (const item of zoneItems) {
        const itemSlug = item.id.split("/").pop() ?? item.id;
        paths.push({
          params: { slug: `${region}/${zone}/${itemSlug}` },
          props: { type: "item", region, zone, zoneName, item },
        });
      }
    }
  }
  return paths;
}

const { type, region, zone, zoneName, items = [], item } = Astro.props as {
  type: "region" | "zone" | "item";
  region: string;
  zone?: string;
  zoneName?: string;
  items?: Item[];
  item?: Item;
};

const waLink = waUrl();

// Etiquetas legibles de región (personaliza al cliente).
const regionLabels: Record<string, string> = {
  // 'cdmx': 'Ciudad de México', 'estado-mexico': 'Estado de México',
  "{{REGION_SLUG}}": "{{REGION_LABEL}}",
};
const regionLabel = regionLabels[region] ?? region;

// ── Datos derivados por tipo de página ──
let title = "";
let description = "";
let breadcrumbs: { label: string; href?: string }[] = [];
const pageType: "directory" | "page" = "directory";
// Componente del cuerpo MDX de la ficha (solo se asigna en type === "item").
let ItemContent: any = null;

if (type === "region") {
  title = `Directorio en ${regionLabel}`;
  description = `{{INTRO_REGION}} en ${regionLabel}.`;
  breadcrumbs = [{ label: "Directorio", href: "/directorio" }, { label: regionLabel }];
} else if (type === "zone") {
  title = `${zoneName} — Directorio`;
  description = `{{INTRO_ZONA}} en ${zoneName}, ${regionLabel}.`;
  breadcrumbs = [
    { label: "Directorio", href: "/directorio" },
    { label: regionLabel, href: `/directorio/${region}` },
    { label: zoneName ?? "" },
  ];
} else if (type === "item" && item) {
  title = item.data.title ?? item.id;
  description = item.data.description ?? `{{FICHA_DESC}}`;
  breadcrumbs = [
    { label: "Directorio", href: "/directorio" },
    { label: regionLabel, href: `/directorio/${region}` },
    { label: zoneName ?? "", href: `/directorio/${region}/${zone}` },
    { label: title },
  ];
  const rendered = await render(item);
  ItemContent = rendered.Content;
}

// schemaData por tipo (claves EXACTAS del contrato lib/seo.ts):
//   listado (region/zone) → list { name, description, path, items[], areaServed }
//                            → buildSchema('directory') emite CollectionPage+ItemList.
//   ficha individual       → en este scaffold la ficha no tiene schema de catálogo
//                            propio; si el item es un LocalBusiness/Place, añade un
//                            constructor en lib/seo.ts y pásalo aquí.
const schemaData =
  type === "item"
    ? {}
    : {
        list: {
          name: title,
          description,
          path: type === "zone" ? `/directorio/${region}/${zone}` : `/directorio/${region}`,
          areaServed: zoneName ?? regionLabel,
          items: items.map((i) => ({
            name: i.data.title,
            path: `/directorio/${region}/${i.data.zoneSlug}/${i.id.split("/").pop() ?? i.id}`,
            description: i.data.description,
          })),
        },
      };
---

<PageLayout
  title={title}
  description={description}
  pageType={pageType}
  schemaData={schemaData}
  breadcrumbs={breadcrumbs}
>
  {/* ── LISTADO (región o zona) ── */}
  {type !== "item" && (
    <>
      <header class="dir-hero">
        <div class="container">
          <h1 class="dir-hero__title">{title}</h1>
          <p class="dir-hero__lede">{description}</p>
        </div>
      </header>

      {/* Sub-zonas (solo en región): enlaza a cada zona */}
      {type === "region" && (
        <section class="dir-section">
          <div class="container">
            <SectionHeading eyebrow="Por zona" title={`Zonas en ${regionLabel}`} />
            <RelatedLinks
              links={[...new Set(items.map((i) => i.data.zoneSlug))].map((z) => ({
                label: items.find((i) => i.data.zoneSlug === z)?.data.zone ?? z,
                href: `/directorio/${region}/${z}`,
              }))}
            />
          </div>
        </section>
      )}

      {/* Grid de fichas */}
      <section class="dir-section">
        <div class="container">
          <SectionHeading title={`${items.length} resultados`} />
          <div class="dir-grid">
            {items.map((i) => {
              const itemSlug = i.id.split("/").pop() ?? i.id;
              return (
                <a class="dir-card" href={`/directorio/${region}/${i.data.zoneSlug}/${itemSlug}`}>
                  <h3 class="dir-card__title">{i.data.title}</h3>
                  {i.data.zone && <p class="dir-card__meta">{i.data.zone}, {regionLabel}</p>}
                  {i.data.description && <p class="dir-card__desc">{i.data.description}</p>}
                </a>
              );
            })}
          </div>
        </div>
      </section>
    </>
  )}

  {/* ── FICHA INDIVIDUAL ── */}
  {type === "item" && item && (
    <article class="dir-detail">
      <header class="dir-hero">
        <div class="container">
          <h1 class="dir-hero__title">{title}</h1>
          {item.data.zone && <p class="dir-hero__meta">{item.data.zone}, {regionLabel}</p>}
        </div>
      </header>
      <div class="container dir-detail__body">
        <div class="prose">
          <ItemContent />
        </div>
        {/* CTA / datos de contacto del item — personaliza con los campos del schema. */}
        <aside class="dir-detail__cta">
          <h2>¿Te interesa?</h2>
          <a class="btn btn--primary btn--block" href={waLink}>Consultar por WhatsApp</a>
        </aside>
      </div>
    </article>
  )}

  <CTABanner
    heading="¿No encuentras lo que buscas?"
    desc="Escríbenos y te ayudamos a encontrar la mejor opción."
    btns={[{ label: "Escríbenos por WhatsApp", href: waLink, icon: "wa", primary: true, external: true }]}
  />
</PageLayout>

<style>
  .dir-hero { padding: var(--space-10) 0 var(--space-4); }
  .dir-hero__title { font-family: var(--font-heading); font-size: var(--text-fluid-3xl); line-height: 1.1; }
  .dir-hero__lede, .dir-hero__meta { color: var(--color-text-muted); margin-top: var(--space-2); }
  .dir-section { padding: var(--space-8) 0; }
  .dir-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); margin-top: var(--space-6); }
  .dir-card { display: block; padding: var(--space-5); border: 1px solid var(--color-border); border-radius: var(--radius-lg); text-decoration: none; color: inherit; transition: box-shadow var(--transition-base, .2s); }
  .dir-card:hover { box-shadow: var(--shadow-md); }
  .dir-card__title { font-size: var(--text-lg); }
  .dir-card__meta { color: var(--color-accent); font-size: var(--text-sm); }
  .dir-card__desc { color: var(--color-text-muted); font-size: var(--text-sm); margin-top: var(--space-2); }
  .dir-detail__body { display: grid; grid-template-columns: 1fr; gap: var(--space-6); padding: var(--space-6) 0 var(--space-10); }
  .dir-detail__cta { padding: var(--space-5); border: 1px solid var(--color-border); border-radius: var(--radius-lg); background: var(--color-surface); align-self: start; }
  .prose { max-width: var(--container-prose); }
  .btn--block { width: 100%; }

  @media (min-width: 768px) {
    .dir-grid { grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }
  }
  @media (min-width: 1024px) {
    .dir-detail__body { grid-template-columns: minmax(0, 1fr) 20rem; }
    .dir-detail__cta { position: sticky; top: calc(var(--header-height, 72px) + var(--space-4)); }
  }
</style>
