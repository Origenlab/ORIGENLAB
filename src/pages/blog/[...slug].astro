---
/**
 * L6 — artículo de blog.
 *
 * UN archivo sustituye a 173 HTML. La estructura, el chrome y el SEO son
 * comunes; lo único propio de cada artículo es su Markdown.
 *
 * El cuerpo se renderiza como HTML tal cual venía. El CSS `.ol-art-*` de cada
 * artículo viaja en `estilos` y se inyecta aquí: el estudio de junio verificó
 * que ese inline es un diseño DISTINTO al de premium-dark.css y que borrarlo
 * tumba páginas. Consolidarlo es un paso posterior con su propio QA visual —
 * no se mezcla con esta migración. Ver _migration/extraer-articulos.py.
 */
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import type { DatosSeo } from '@lib/seo';

export async function getStaticPaths() {
  const articulos = await getCollection('articulos');
  return articulos.map((a) => ({ params: { slug: a.id }, props: { articulo: a } }));
}

const { articulo } = Astro.props;
const { Content } = await render(articulo);
const d = articulo.data;

const seo: DatosSeo = {
  titulo: d.titulo,
  descripcion: d.descripcion,
  ogTitulo: d.ogTitulo,
  ogDescripcion: d.ogDescripcion,
  canonical: `/blog/${articulo.id}/`,
  tipo: 'articulo',
  imagen: d.thumb,
  noindex: d.noindex,
  faq: d.faq,
  breadcrumbs: [
    { nombre: 'Inicio', url: '/' },
    { nombre: 'Blog', url: '/blog/' },
    { nombre: d.h1, url: `/blog/${articulo.id}/` },
  ],
};
---

<BaseLayout {...seo} acento={d.acento}>
  {d.estilos && <style is:inline set:html={d.estilos} slot="head" />}
  <Content />
</BaseLayout>
