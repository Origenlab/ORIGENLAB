  (function() {
    var btns = document.querySelectorAll('#ol-faq-list-dw .ol-faq-question');
    btns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var idx = btn.getAttribute('data-faq');
        var answer = document.getElementById('faq-ans-' + idx);
        var isOpen = btn.classList.contains('active');
        btns.forEach(function(b) {
          b.classList.remove('active');
          var a = document.getElementById('faq-ans-' + b.getAttribute('data-faq'));
          if (a) a.style.maxHeight = null;
        });
        if (!isOpen && answer) {
          btn.classList.add('active');
          answer.style.maxHeight = answer.scrollHeight + 'px';
        }
