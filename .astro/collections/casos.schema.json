{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "titulo": {
      "type": "string",
      "minLength": 10
    },
    "descripcion": {
      "type": "string",
      "minLength": 50,
      "maxLength": 160
    },
    "imagen": {
      "type": "string"
    },
    "noindex": {
      "default": false,
      "type": "boolean"
    },
    "marca": {
      "type": "string"
    },
    "sector": {
      "type": "string",
      "enum": [
        "equipos-contra-incendios",
        "seguridad-privada",
        "equipo-para-eventos"
      ]
    },
    "orden": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "dominio": {
      "type": "string",
      "format": "uri"
    },
    "acento": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "h1": {
      "type": "string",
      "maxLength": 60
    },
    "cliente": {
      "default": {},
      "type": "object",
      "properties": {
        "telefono": {
          "type": "string"
        },
        "whatsapp": {
          "type": "string"
        },
        "fundacion": {
          "type": "string"
        },
        "cobertura": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "faq": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "pregunta": {
            "type": "string"
          },
          "respuesta": {
            "type": "string"
          }
        },
        "required": [
          "pregunta",
          "respuesta"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "titulo",
    "descripcion",
    "marca",
    "sector",
    "dominio",
    "acento",
    "h1"
  ]
}