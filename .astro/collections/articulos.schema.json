{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "titulo": {
      "type": "string",
      "minLength": 10
    },
    "descripcion": {
      "type": "string",
      "minLength": 50,
      "maxLength": 160
    },
    "imagen": {
      "type": "string"
    },
    "noindex": {
      "default": false,
      "type": "boolean"
    },
    "h1": {
      "type": "string",
      "maxLength": 60
    },
    "categoria": {
      "type": "string",
      "enum": [
        "pci",
        "eventos",
        "estrategia",
        "seguridad",
        "rendimiento",
        "diseno",
        "tecnologia",
        "ecommerce",
        "agencia"
      ]
    },
    "categoriaLabel": {
      "type": "string"
    },
    "fecha": {
      "type": "string",
      "format": "date-time"
    },
    "minutos": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "thumb": {
      "type": "string"
    },
    "thumbAlt": {
      "type": "string",
      "minLength": 10
    },
    "acento": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "faq": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "pregunta": {
            "type": "string"
          },
          "respuesta": {
            "type": "string"
          }
        },
        "required": [
          "pregunta",
          "respuesta"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "titulo",
    "descripcion",
    "h1",
    "categoria",
    "categoriaLabel",
    "fecha",
    "minutos",
    "thumb",
    "thumbAlt"
  ]
}